<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login &mdash; Expense Tracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/expense-tracker/assets/style.css">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-box">
        <div class="auth-logo">&#128176;</div>
        <h2>Expense Tracker</h2>

        {% if error %}
        <div class="alert alert-danger py-2 small">{{ error }}</div>
        {% endif %}

        <form method="post" action="/expense-tracker/login.php">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" name="email" class="form-control" required
                       autocomplete="email" placeholder="you@example.com">
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" required
                       autocomplete="current-password" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;">
            </div>

            <div class="mb-4">
                <label class="form-label">Security check: What is {{ captcha_q }}?</label>
                <input type="text" name="captcha" class="form-control" required
                       placeholder="Enter the answer" autocomplete="off">
            </div>

            <button type="submit" name="login" class="btn btn-primary w-100">Sign in</button>
        </form>

        <p class="auth-divider mt-3">
            Don't have an account? <a href="/expense-tracker/register.php">Create one</a>
        </p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

