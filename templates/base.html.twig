<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Expense Tracker{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/expense-tracker/assets/style.css">
    {% block extra_css %}{% endblock %}
</head>
<body>

{% if logged_in %}
<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/expense-tracker/welcome.php">&#128176; Expense Tracker</a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                <li class="nav-item">
                    <a class="nav-link" href="/expense-tracker/expense_tracker.php">&#128203; Expenses</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/expense-tracker/add-expense-form.php">&#43; Add</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/expense-tracker/search-expense.php">&#128269; Search</a>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-2 flex-wrap">
                {% if budget > 0 %}
                <span class="navbar-text small">
                    &pound;{{ total_spent|number_format(2) }} / &pound;{{ budget|number_format(2) }}
                </span>
                {% endif %}
                <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#budgetModal">
                    &#127775; Budget
                </button>
                <span class="navbar-text small">{{ username }}</span>
                <a class="btn btn-sm btn-danger" href="/expense-tracker/logout.php">Logout</a>
            </div>
        </div>
    </div>
</nav>
{% endif %}

<div class="container mt-4 mb-5">

    {% if flash_success %}
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
        <span>&#10003;</span> {{ flash_success }}
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    {% if flash_error %}
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
        <span>&#9888;</span> {{ flash_error }}
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    {% block body %}{% endblock %}

</div>

{% if logged_in %}
<!-- Budget Modal -->
<div class="modal fade" id="budgetModal" tabindex="-1" aria-labelledby="budgetLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content" style="border-radius:12px; border:none; box-shadow: 0 8px 30px rgba(0,0,0,0.15);">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="budgetLabel">&#127775; Set Monthly Budget</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">Set your spending limit for this month.</p>
                <div class="input-group mb-2">
                    <span class="input-group-text">&pound;</span>
                    <input type="number" step="0.01" min="0" id="budgetAmount"
                           class="form-control" value="{{ budget }}" placeholder="e.g. 500.00">
                </div>
                <div id="budgetMsg"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="saveBudgetBtn">Save</button>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

{% if logged_in %}
<script>
// Scripts at bottom of body — DOM is already loaded, no need for DOMContentLoaded
var saveBtn = document.getElementById('saveBudgetBtn');
if (saveBtn) {
    saveBtn.addEventListener('click', function () {
        var amount = parseFloat(document.getElementById('budgetAmount').value);
        var msgDiv = document.getElementById('budgetMsg');

        if (isNaN(amount) || amount < 0) {
            msgDiv.innerHTML = '<div class="alert alert-danger py-1 small">Please enter a valid amount.</div>';
            return;
        }

        saveBtn.disabled    = true;
        saveBtn.textContent = 'Saving...';
        msgDiv.innerHTML    = '';

        var formData = new FormData();
        formData.append('budget',     amount);
        formData.append('csrf_token', '{{ csrf_token }}');

        fetch('/expense-tracker/budget-update.php', {
            method:      'POST',
            body:        formData,
            credentials: 'same-origin'
        })
        .then(function (r) { return r.text(); })
        .then(function (text) {
            try {
                var data = JSON.parse(text);
                if (data.success) {
                    msgDiv.innerHTML = '<div class="alert alert-success py-1 small">&#10003; Budget saved!</div>';
                    setTimeout(function () { location.reload(); }, 900);
                } else {
                    msgDiv.innerHTML = '<div class="alert alert-danger py-1 small">' + data.error + '</div>';
                    saveBtn.disabled    = false;
                    saveBtn.textContent = 'Save';
                }
            } catch (e) {
                msgDiv.innerHTML = '<div class="alert alert-danger py-1 small">Response: ' + text.substring(0, 200) + '</div>';
                saveBtn.disabled    = false;
                saveBtn.textContent = 'Save';
            }
        })
        .catch(function (err) {
            msgDiv.innerHTML = '<div class="alert alert-danger py-1 small">Network error: ' + err + '</div>';
            saveBtn.disabled    = false;
            saveBtn.textContent = 'Save';
        });
    });
}
</script>
{% endif %}

{% block extra_js %}{% endblock %}

</body>
</html>

