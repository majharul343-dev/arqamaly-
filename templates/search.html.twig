{% extends "base.html.twig" %}

{% block title %}Search Expenses &mdash; Expense Tracker{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
{% endblock %}

{% block body %}

<div class="page-header">
    <h4>&#128269; Search Expenses</h4>
    <span id="resultBadge" class="result-count" style="display:none;"></span>
</div>

<div class="search-panel">
    <div class="search-title">Filter by one or more criteria</div>
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Keyword</label>
            <input type="text" id="searchName" class="form-control" placeholder="Search by name...">
        </div>
        <div class="col-md-3">
            <label class="form-label">Category</label>
            <select id="searchCategory" class="form-select">
                <option value="">All categories</option>
                <option value="Food">Food</option>
                <option value="Transport">Transport</option>
                <option value="Entertainment">Entertainment</option>
                <option value="Bills">Bills</option>
                <option value="Shopping">Shopping</option>
                <option value="Health">Health</option>
                <option value="Education">Education</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Date from</label>
            <input type="date" id="searchDateFrom" class="form-control">
        </div>
        <div class="col-md-2">
            <label class="form-label">Date to</label>
            <input type="date" id="searchDateTo" class="form-control">
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button id="clearBtn" class="btn btn-outline-secondary w-100" title="Clear filters">&#10005;</button>
        </div>
    </div>
    <div class="row g-3 mt-0">
        <div class="col-md-2">
            <label class="form-label">Min (&pound;)</label>
            <input type="number" step="0.01" min="0" id="searchAmountMin"
                   class="form-control" placeholder="0.00">
        </div>
        <div class="col-md-2">
            <label class="form-label">Max (&pound;)</label>
            <input type="number" step="0.01" min="0" id="searchAmountMax"
                   class="form-control" placeholder="any">
        </div>
    </div>
</div>

<div id="searchResults"></div>

{% endblock %}

{% block extra_js %}
<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
<script>
function doSearch() {
    $.ajax({
        url: '/expense-tracker/search-results.php',
        type: 'GET',
        data: {
            name:       $('#searchName').val(),
            category:   $('#searchCategory').val(),
            date_from:  $('#searchDateFrom').val(),
            date_to:    $('#searchDateTo').val(),
            amount_min: $('#searchAmountMin').val(),
            amount_max: $('#searchAmountMax').val()
        },
        success: function (html) {
            $('#searchResults').html(html);
            var count = $('#searchResults tbody tr').length;
            if (count > 0) {
                $('#resultBadge').text(count + ' result' + (count !== 1 ? 's' : '')).show();
            } else {
                $('#resultBadge').hide();
            }
        }
    });
}

$(document).ready(function () {
    doSearch();

    $('#searchName, #searchCategory, #searchDateFrom, #searchDateTo, #searchAmountMin, #searchAmountMax')
        .on('input change', doSearch);

    $('#searchName').autocomplete({
        source: '/expense-tracker/search-suggestions.php',
        minLength: 1,
        select: function () { setTimeout(doSearch, 80); }
    });

    $('#clearBtn').on('click', function () {
        $('#searchName, #searchDateFrom, #searchDateTo, #searchAmountMin, #searchAmountMax').val('');
        $('#searchCategory').val('');
        $('#resultBadge').hide();
        doSearch();
    });
});
</script>
{% endblock %}

