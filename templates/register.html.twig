<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register &mdash; Expense Tracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/expense-tracker/assets/style.css">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-box">
        <div class="auth-logo">&#128176;</div>
        <h2>Create Account</h2>

        {% if error %}
        <div class="alert alert-danger py-2 small">{{ error }}</div>
        {% endif %}

        {% if success %}
        <div class="alert alert-success py-2 small">
            Registration successful! <a href="/expense-tracker/login.php" class="fw-bold">Sign in now &rarr;</a>
        </div>
        {% endif %}

        <form method="post" action="/expense-tracker/register.php">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control" required
                       maxlength="50" autocomplete="username" placeholder="Your name">
            </div>

            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" name="email" class="form-control" required
                       autocomplete="email" placeholder="you@example.com">
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" required
                       minlength="6" autocomplete="new-password" placeholder="Min. 6 characters">
            </div>

            <div class="mb-4">
                <label class="form-label">Security check: What is {{ captcha_q }}?</label>
                <input type="text" name="captcha" class="form-control" required
                       placeholder="Enter the answer" autocomplete="off">
            </div>

            <button type="submit" name="register" class="btn btn-success w-100">Create Account</button>
        </form>

        <p class="auth-divider mt-3">
            Already have an account? <a href="/expense-tracker/login.php">Sign in</a>
        </p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

